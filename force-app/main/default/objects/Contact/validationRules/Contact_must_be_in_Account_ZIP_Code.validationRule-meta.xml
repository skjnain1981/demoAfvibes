<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Contact_must_be_in_Account_ZIP_Code</fullName>
    <active>false</active>
    <errorConditionFormula>AND(Account.ShippingPostalCode &lt;&gt; MailingPostalCode,NOT(ISBLANK( AccountId )))</errorConditionFormula>
    <errorDisplayField>MailingPostalCode</errorDisplayField>
    <errorMessage>Contact Mailing Postal code is different from account shipping postal code</errorMessage>
</ValidationRule>
